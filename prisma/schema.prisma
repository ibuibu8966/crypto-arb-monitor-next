generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model spread_log {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime @db.Timestamptz(6)
  symbol         String   @db.VarChar(50)
  mexc           Float?
  bitget         Float?
  coinex         Float?
  mx_bg_pct      Float?
  mx_cx_pct      Float?
  bg_cx_pct      Float?
  max_spread_pct Float?

  @@index([symbol, timestamp(sort: Desc)], map: "idx_symbol_ts")
  @@index([timestamp(sort: Desc)], map: "idx_timestamp")
}

/// 統計キャッシュ（getStats相当の事前計算結果）
model spread_stats_cache {
  id            Int       @id @default(autoincrement())
  symbol        String    @db.VarChar(50)
  time_range    String    @db.VarChar(10)
  avg_spread    Float?
  max_spread    Float?
  min_spread    Float?
  std_spread    Float?
  count         Int?
  best_pair     String?   @db.VarChar(10)
  crossings_20  Int?
  crossings_80  Int?
  signed_min     Float?
  signed_max     Float?
  current_pos    Float?
  reversion_prob Float?
  half_life      Float?
  cost_ratio     Float?
  exec_volume    Float?
  vol_stability  Float?
  arb_score      Float?
  calculated_at  DateTime? @db.Timestamptz(6)

  @@unique([symbol, time_range])
}

